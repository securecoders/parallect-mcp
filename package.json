  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vercel/node": "^5.6.24",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
