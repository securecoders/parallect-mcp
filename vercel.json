{
  "rewrites": [
    { "source": "/mcp", "destination": "/api/mcp" }
  ],
  "functions": {
    "api/mcp.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/mcp",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Authorization, Content-Type" }
      ]
    }
  ]
}
